    "phrases": [
      {
        "text": "艺术家在画画。",
        "translation": "The artist is painting.",
        "audio": "audio/zh/yishujia_phrase_1.mp3",
        "roman": "Yìshùjiā zài huà huà.",
        "trad": "藝術家在畫畫。"
      },
      {
        "text": "很多艺术家在成功之前都有过很长一段时间的奋斗。",
        "translation": "Many artists struggle for a long time before achieving success.",
        "audio": "audio/zh/yishujia_phrase_2.mp3",
        "roman": "Hěn duō yìshùjiā zài chénggōng zhīqián dōu yǒuguò hěncháng yí duàn shíjiān de fèndòu.",
        "trad": "很多藝術家在成功之前都有過很長一段時間的奮鬥。"
      },
      {
        "text": "那个艺术家在用毛笔写汉字。",
        "translation": "The artist is drawing Chinese characters with a writing brush.",
        "audio": "audio/zh/yishujia_phrase_3.mp3",
        "roman": "Nàgè yìshùjiā zài yòng máobǐ xiě hànzì.",
        "trad": "那個藝術家在用毛筆寫漢字。"
      },
      {
        "text": "有天赋的艺术家",
        "translation": "talented artist",
        "audio": "audio/zh/yishujia_phrase_4.mp3",
        "roman": "yǒu tiānfù de yìshùjiā",
        "trad": "有天賦的藝術家"
      }
    ]
  },
